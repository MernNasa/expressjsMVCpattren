<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Beautiful Home Page</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', sans-serif;
    }

    body {
      background: #0f172a;
      color: white;
    }

    /* Navbar */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 50px;
      background: rgba(255,255,255,0.05);
      backdrop-filter: blur(10px);
      position: sticky;
      top: 0;
    }

    .logo {
      font-size: 24px;
      font-weight: bold;
      color: #38bdf8;
    }

    .nav-links {
      list-style: none;
      display: flex;
      gap: 25px;
    }

    .nav-links li a {
      text-decoration: none;
      color: white;
      transition: 0.3s;
      position: relative;
    }

    .nav-links li a::after {
      content: "";
      position: absolute;
      width: 0%;
      height: 2px;
      left: 0;
      bottom: -5px;
      background: #38bdf8;
      transition: 0.3s;
    }

    .nav-links li a:hover::after {
      width: 100%;
    }

    .btn {
      padding: 8px 18px;
      background: #38bdf8;
      border: none;
      border-radius: 20px;
      color: #000;
      cursor: pointer;
      transition: 0.3s;
    }

    .btn:hover {
      background: #0ea5e9;
    }

    /* Hero Section */
    .hero {
      height: 90vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      background: linear-gradient(to right, #0f172a, #1e293b);
      padding: 20px;
    }

    .hero h1 {
      font-size: 50px;
      margin-bottom: 20px;
    }

    .hero p {
      font-size: 18px;
      margin-bottom: 30px;
      color: #cbd5f5;
    }

    .hero button {
      padding: 12px 30px;
      border: none;
      border-radius: 30px;
      background: #38bdf8;
      font-size: 16px;
      cursor: pointer;
      transition: 0.3s;
    }

    .hero button:hover {
      transform: scale(1.05);
      background: #0ea5e9;
    }

    /* Responsive */
    @media(max-width: 768px) {
      nav {
        flex-direction: column;
        gap: 10px;
      }

      .hero h1 {
        font-size: 32px;
      }
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav>
    <div class="logo">MyBrand</div>

    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/features">Features</a></li>
      <li><a href="/pricing">Pricing</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>

    <button class="btn">Login</button>
  </nav>

  <!-- Hero Section -->
  <section class="hero">
    <div>
      <h1>Build Beautiful Websites 🚀</h1>
      <p>Create modern and responsive web designs with ease.</p>
      <button>Get Started</button>
    </div>
  </section>

</body>
</html>